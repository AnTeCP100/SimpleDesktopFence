<Window x:Class="SimpleDesktopFence.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Settings"
        WindowStyle="None"
        Width="320" Height="500"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome ResizeBorderThickness="6"
                          CaptionHeight="0"
                          GlassFrameThickness="0"
                          UseAeroCaptionButtons="False"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>
    <Window.Resources>
        <SolidColorBrush x:Key="Bg"       Color="#F01A1A2E"/>
        <SolidColorBrush x:Key="TitleBg"  Color="#44000000"/>
        <SolidColorBrush x:Key="Border"   Color="#55FFFFFF"/>
        <SolidColorBrush x:Key="Text"     Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Dim"      Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="HoverBg"  Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="InputBg"  Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="DivBg"    Color="#22FFFFFF"/>

        <!-- Title bar close button -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="#CCFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Dim}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,12,0,4"/>
        </Style>

        <!-- Value label -->
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="{StaticResource Text}"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Input text box -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- Generic action button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="DoneBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#55336699"/>
            <Setter Property="Width"      Value="80"/>
            <Setter Property="Height"     Value="30"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource Bg}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="48"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="{StaticResource TitleBg}"
                        CornerRadius="8,8,0,0"
                        MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid Margin="12,0,6,0">
                        <TextBlock Text="Panel Settings"
                                   Foreground="{StaticResource Text}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource TitleBtn}"
                                Content="✕"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="CloseBtn_Click"/>
                    </Grid>
                </Border>

                <!-- Settings content -->
                <ScrollViewer Grid.Row="1"
                              Margin="16,4,16,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- ── Folder ── -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="FOLDER"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FolderPathBox"
                                     Grid.Column="0"
                                     Style="{StaticResource InputBox}"
                                     IsReadOnly="True"
                                     Text="{Binding FolderPath, Mode=OneWay}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource ActionBtn}"
                                    Content="Browse"
                                    Click="BrowseFolder_Click"/>
                        </Grid>

                        <TextBlock Style="{StaticResource SectionLabel}" Text="TOOLBAR"/>

                        <TextBlock Style="{StaticResource ValueLabel}" 
                                   Text="Button Label" 
                                   Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" 
                                 Text="{Binding ToolbarLabel, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,2"/>
                        <TextBlock Text="Leave empty to use folder name"
                                   Foreground="{StaticResource Dim}"
                                   FontSize="10"
                                   Margin="0,0,0,8"/>

                        <!-- ── Appearance ── -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="APPEARANCE"/>

                        <!-- Color row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Background Color"
                                       Style="{StaticResource ValueLabel}"/>
                            <Button x:Name="ColorPreviewBtn"
                                    Grid.Column="2"
                                    Width="60"
                                    Height="28"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Click="PickColor_Click"
                                    ToolTip="Click to choose color"/>
                        </Grid>

                        <!-- Opacity row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Opacity"
                                       Style="{StaticResource ValueLabel}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding OpacityPercent}"
                                       Style="{StaticResource ValueLabel}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Slider x:Name="OpacitySlider"
                                Minimum="0.25" Maximum="1.0"
                                SmallChange="0.05" LargeChange="0.1"
                                TickFrequency="0.05"
                                Value="{Binding BackgroundOpacity}"
                                Margin="0,0,0,8"/>

                        <!-- Font size row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Font Size" Style="{StaticResource ValueLabel}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding FontSize, StringFormat={}{0:F0} pt}"
                                       Style="{StaticResource ValueLabel}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Slider Minimum="8" Maximum="22"
                                SmallChange="1" LargeChange="2"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding FontSize}"
                                Margin="0,0,0,8"/>

                        <!-- ── Columns ── -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="VISIBLE COLUMNS"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox Content="Size" IsChecked="{Binding ShowSize}" Margin="0,0,16,0"/>
                            <CheckBox Content="Type" IsChecked="{Binding ShowType}" Margin="0,0,16,0"/>
                            <CheckBox Content="Date" IsChecked="{Binding ShowDate}"/>
                        </StackPanel>

                        <!-- ── File names ── -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="FILE NAMES"/>
                        <CheckBox Content="Show file extensions  (e.g. document.docx)"
                                  IsChecked="{Binding ShowExtension}"
                                  Margin="0,0,0,4"/>

                        <!-- ── Behavior ── -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="BEHAVIOR"/>
                        <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Always on top" IsChecked="{Binding AlwaysOnTop}" Margin="0,0,0,4"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2"
                        Background="{StaticResource TitleBg}"
                        CornerRadius="0,0,8,8">
                    <Grid Margin="16,0,16,0">
                        <Button Style="{StaticResource ActionBtn}"
                                Content="Reset to Default"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Click="ResetDefault_Click"/>
                        <Button Style="{StaticResource DoneBtn}"
                                Content="Done"
                                HorizontalAlignment="Right"
                                Click="CloseBtn_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>

</Window>
