<Window x:Class="SimpleDesktopFence.Views.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SimpleDesktopFence Toolbar"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Height="44"
        SizeToContent="Width">

    <!-- WindowChrome removes system chrome but keeps hardware rendering -->
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome ResizeBorderThickness="0"
                                  CaptionHeight="0"
                                  GlassFrameThickness="0"
                                  UseAeroCaptionButtons="False"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>

    <Window.Resources>
        <SolidColorBrush x:Key="TextMain"    Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="TextDim"     Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="TabBg"       Color="#33000000"/>
        <SolidColorBrush x:Key="BorderClr"   Color="#44FFFFFF"/>
        <SolidColorBrush x:Key="BtnHover"    Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="BtnActive"   Color="#55FFFFFF"/>

        <!-- Panel name button style -->
        <Style x:Key="PanelBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="MinWidth"        Value="80"/>
            <Setter Property="MaxWidth"        Value="150"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Margin="2,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BtnActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root grid: two rows; order is swapped for Bottom position in code-behind -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: toolbar bar (36px) -->
            <RowDefinition x:Name="BarRow"  Height="36"/>
            <!-- Row 1: always-visible tab strip (8px) -->
            <RowDefinition x:Name="TabRow"  Height="8"/>
        </Grid.RowDefinitions>

        <!-- ── Main toolbar bar ── -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="0"
                Background="#EE1A1A2E"
                BorderBrush="{StaticResource BorderClr}"
                BorderThickness="0,0,0,1"
                Cursor="SizeAll"
                MouseLeftButtonDown="ToolbarBar_MouseDown"
                MouseMove="ToolbarBar_MouseMove"
                MouseLeftButtonUp="ToolbarBar_MouseUp">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="4,0">
                <!-- Panel buttons are added here dynamically in code-behind -->
                <StackPanel x:Name="ButtonsPanel"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"/>
            </ScrollViewer>
        </Border>

        <!-- ── Tab strip (always 8px visible, indicates toolbar is present) ── -->
        <Border x:Name="TabStrip"
                Grid.Row="1"
                Background="{StaticResource TabBg}"
                BorderBrush="{StaticResource BorderClr}"
                BorderThickness="0,1,0,0">
            <!-- Chevron indicator in the centre -->
            <TextBlock x:Name="TabChevron"
                       Text="▼"
                       FontSize="7"
                       Foreground="{StaticResource TextDim}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
